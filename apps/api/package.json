{
  "name": "@signage/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "create-superadmin": "tsx src/cli/create-superadmin.ts",
    "reset-superadmin-password": "tsx src/cli/reset-superadmin-password.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.682.0",
    "@aws-sdk/lib-storage": "^3.682.0",
    "@aws-sdk/s3-request-presigner": "^3.682.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/websocket": "^11.0.1",
    "@signage/database": "workspace:*",
    "@signage/media": "workspace:*",
    "@signage/scheduler": "workspace:*",
    "@signage/shared": "workspace:*",
    "@signage/sync-protocol": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.2",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
