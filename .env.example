# ----- Database -----
DATABASE_URL=postgresql://signage:signage@localhost:5432/signage

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- API server -----
API_HOST=0.0.0.0
API_PORT=4000
# Public base URL of the API as reachable by devices and browsers
API_PUBLIC_URL=http://localhost:4000
# Secret used to sign user JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Access token lifetime
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed dashboard origins
CORS_ORIGINS=http://localhost:5173

# ----- Object storage (S3-compatible, MinIO in dev) -----
S3_ENDPOINT=http://localhost:9000
# Endpoint used inside presigned URLs handed to browsers/devices.
# In dev this must be reachable from the host; in prod use your public S3/CDN endpoint.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=signage-media
S3_ACCESS_KEY=signage
S3_SECRET_KEY=signage-secret
S3_FORCE_PATH_STYLE=true

# ----- Uploads / media -----
# Maximum upload size in bytes (default 1 GiB)
MAX_UPLOAD_SIZE_BYTES=1073741824
# Maximum output video height for transcoding (1080 keeps RPi4/ODROID-C4 happy)
MAX_VIDEO_HEIGHT=1080
# Maximum output frame rate. 30 is safe for ARM SBC hardware decoders; raise only
# if your players are all beefy (1080p50/60 needs a strong decoder).
MAX_VIDEO_FPS=30
# Target video bitrate for the processed variant
VIDEO_BITRATE_KBPS=6000
# Bitrate for the low-bandwidth fallback variant
FALLBACK_VIDEO_BITRATE_KBPS=2000
# Set to "false" to skip creating fallback variants
CREATE_FALLBACK_VARIANT=true
# Paths to ffmpeg/ffprobe binaries (leave as-is if on PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ----- Superadmin bootstrap -----
# When set (all three) and no superadmin exists yet, the API creates this
# account on startup. Existing superadmins are never overwritten and the
# password is never logged. Minimum 12 characters.
INITIAL_SUPERADMIN_EMAIL=
INITIAL_SUPERADMIN_PASSWORD=
INITIAL_SUPERADMIN_NAME=

# ----- Pairing -----
# Pairing code lifetime in minutes
PAIRING_CODE_TTL_MINUTES=15

# ----- Worker -----
WORKER_CONCURRENCY=2

# ----- Web dashboard (Vite) -----
VITE_API_URL=http://localhost:4000

# ----- Mock device (apps/mock-device) -----
MOCK_DEVICE_BACKEND_URL=http://localhost:4000
MOCK_DEVICE_PAIRING_CODE=
MOCK_DEVICE_PORT=8080
