generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum OrgRole {
  owner
  admin
  editor
  viewer
}

enum GlobalRole {
  user
  superadmin
}

enum OrgStatus {
  active
  disabled
}

enum PlaybackOrderMode {
  manual_order
  alphabetical
  random
  random_with_priority_rules
}

enum PlaylistItemType {
  media
  folder
}

enum PrioritySelectionMode {
  rotate
  random
}

enum DeviceOrientation {
  landscape
  portrait
}

enum MediaType {
  image
  video
}

enum MediaOrientation {
  landscape
  portrait
  square
}

enum ProcessingStatus {
  pending
  processing
  ready
  failed
}

enum MediaVariantKind {
  original
  processed
  fallback
  thumbnail
  video_high
  video_standard
  video_light
}

enum PlaybackProfile {
  high
  standard
  light
}

enum FitMode {
  contain
  cover
  stretch
  original
  scale_down
}

enum PositionMode {
  center
  top
  bottom
  left
  right
  top_left
  top_right
  bottom_left
  bottom_right
}

enum CommandStatus {
  pending
  sent
  acked
  completed
  failed
  expired
}

enum SyncStatusValue {
  never_synced
  in_sync
  syncing
  error
}

enum PlaybackEventType {
  start
  end
  error
  skip
}

enum ProcessingJobStatus {
  queued
  running
  completed
  failed
}

// ============================================================
// Users & organizations
// ============================================================

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  name               String
  globalRole         GlobalRole @default(user)
  mustChangePassword Boolean    @default(false)
  disabledAt         DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  memberships        OrganizationMember[]
  createdCommands    DeviceCommand[]
  emergencyOverrides EmergencyOverride[]
  createdFolders     MediaFolder[]
  auditLogs          AuditLog[]           @relation("AuditActor")

  @@map("users")
}

model Organization {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  status       OrgStatus @default(active)
  planName     String?
  maxDevices   Int?
  maxStorageGb Int?
  // Branding. Logos are stored in object storage (S3/MinIO); only the key and
  // metadata live here. See the org logo endpoints in routes/orgs.ts.
  logoStorageKey       String?
  logoMimeType         String?
  logoOriginalFilename String?
  logoSizeBytes        Int?
  logoUpdatedAt        DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  members            OrganizationMember[]
  devices            Device[]
  deviceGroups       DeviceGroup[]
  mediaAssets        MediaAsset[]
  mediaFolders       MediaFolder[]
  playlists          Playlist[]
  schedules          Schedule[]
  emergencyOverrides EmergencyOverride[]
  priorityRules      PlaylistPriorityRule[]
  auditLogs          AuditLog[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ============================================================
// Devices
// ============================================================

model Device {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  description    String?
  orientation    DeviceOrientation @default(landscape)
  // Software rotation (clockwise degrees: 0/90/180/270) compensating for how
  // the panel is physically mounted; orthogonal to orientation.
  rotation       Int               @default(0)
  timezone       String            @default("UTC")
  // Video quality tier served to this device. Defaults to the safe `standard`
  // (1080p30) tier; auto-suggested in the dashboard from `deviceModel`.
  playbackProfile PlaybackProfile  @default(standard)

  // Pairing. The code is short-lived, single-use and shown in the dashboard
  // until used, so it is stored in plaintext by design (unlike device tokens,
  // which are stored hashed).
  pairingCode          String?   @unique
  pairingCodeExpiresAt DateTime?
  pairedAt             DateTime?

  // Status (reported by the device)
  lastSeenAt     DateTime?
  lastIp         String?
  appVersion     String?
  osInfo         String?
  archInfo       String?
  // Board model reported by the device (e.g. "Raspberry Pi 4 Model B",
  // "Hardkernel ODROID-C4"); used to auto-suggest a playback tier.
  deviceModel    String?
  uptimeSeconds  Float?
  cpuPercent     Float?
  memUsedBytes   BigInt?
  memTotalBytes  BigInt?
  diskFreeBytes  BigInt?
  diskTotalBytes BigInt?
  cacheUsedBytes BigInt?
  screenWidth    Int?
  screenHeight   Int?
  networkType    String?
  lastError      String?

  // Sync / playback state
  syncStatus        SyncStatusValue @default(never_synced)
  lastSyncAt        DateTime?
  manifestVersion   String?
  currentPlaylistId String?
  currentMediaId    String?
  defaultPlaylistId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultPlaylist  Playlist?                 @relation("DeviceDefaultPlaylist", fields: [defaultPlaylistId], references: [id], onDelete: SetNull)
  tokens           DeviceToken[]
  groupMemberships DeviceGroupMembership[]
  scheduleLinks    ScheduleDeviceAssignment[]
  emergencyLinks   EmergencyOverrideDevice[]
  commands         DeviceCommand[]
  heartbeats       DeviceHeartbeat[]
  logs             DeviceLog[]
  playbackEvents   PlaybackEvent[]
  screenshots      DeviceScreenshot[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, name])
  @@map("devices")
}

model DeviceToken {
  id         String    @id @default(cuid())
  deviceId   String
  tokenHash  String    @unique
  name       String?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("device_tokens")
}

model DeviceGroup {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    DeviceGroupMembership[]
  scheduleLinks  ScheduleGroupAssignment[]
  emergencyLinks EmergencyOverrideGroup[]

  @@index([organizationId, deletedAt])
  @@map("device_groups")
}

model DeviceGroupMembership {
  id        String   @id @default(cuid())
  deviceId  String
  groupId   String
  createdAt DateTime @default(now())

  device Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  group  DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([deviceId, groupId])
  @@index([groupId])
  @@map("device_group_memberships")
}

// ============================================================
// Media
// ============================================================

model MediaFolder {
  id              String    @id @default(cuid())
  organizationId  String
  parentFolderId  String?
  name            String
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentFolder MediaFolder?  @relation("FolderTree", fields: [parentFolderId], references: [id], onDelete: SetNull)
  subfolders   MediaFolder[] @relation("FolderTree")
  createdBy    User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  mediaAssets             MediaAsset[]
  playlistItems           PlaylistItem[]
  priorityRuleAssignments PlaylistPriorityRuleAssignment[]

  @@index([organizationId, parentFolderId, deletedAt])
  @@map("media_folders")
}

model MediaAsset {
  id                 String           @id @default(cuid())
  organizationId     String
  folderId           String?
  name               String
  originalFilename   String
  mediaType          MediaType
  originalMimeType   String
  processedMimeType  String?
  originalStorageKey String
  processedStorageKey String?
  thumbnailStorageKey String?
  durationSeconds    Float?
  width              Int?
  height             Int?
  orientation        MediaOrientation?
  processingStatus   ProcessingStatus @default(pending)
  processingError    String?
  sizeBytes          BigInt?
  processedSizeBytes BigInt?
  checksumSha256     String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folder         MediaFolder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  variants       MediaVariant[]
  playlistItems  PlaylistItem[]
  emergencyOverrides EmergencyOverride[]
  playbackEvents PlaybackEvent[]
  processingJobs MediaProcessingJob[]
  priorityRuleAssignments PlaylistPriorityRuleAssignment[]

  @@index([organizationId, deletedAt, mediaType])
  @@index([organizationId, processingStatus])
  @@index([organizationId, folderId, deletedAt])
  @@map("media_assets")
}

model MediaVariant {
  id             String           @id @default(cuid())
  mediaAssetId   String
  kind           MediaVariantKind
  storageKey     String
  mimeType       String
  width          Int?
  height         Int?
  bitrateKbps    Int?
  sizeBytes      BigInt
  checksumSha256 String
  createdAt      DateTime         @default(now())

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, kind])
  @@map("media_variants")
}

model MediaProcessingJob {
  id           String              @id @default(cuid())
  mediaAssetId String
  status       ProcessingJobStatus @default(queued)
  attempts     Int                 @default(0)
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId, status])
  @@map("media_processing_jobs")
}

// ============================================================
// Playlists & schedules
// ============================================================

model Playlist {
  id                          String            @id @default(cuid())
  organizationId              String
  name                        String
  description                 String?
  loop                        Boolean           @default(true)
  defaultImageDurationSeconds Int               @default(10)
  playbackOrderMode           PlaybackOrderMode @default(manual_order)
  // Display defaults applied to items whose own value is unset.
  defaultFitMode              FitMode?
  defaultBackgroundColor      String?
  defaultPositionMode         PositionMode?
  clonedFromPlaylistId        String?
  clonedAt                    DateTime?
  createdByUserId             String?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  deletedAt                   DateTime?

  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clonedFrom         Playlist?              @relation("PlaylistClones", fields: [clonedFromPlaylistId], references: [id], onDelete: SetNull)
  clones             Playlist[]             @relation("PlaylistClones")
  items              PlaylistItem[]
  priorityRules      PlaylistPriorityRule[]
  schedules          Schedule[]
  emergencyOverrides EmergencyOverride[]
  defaultForDevices  Device[]               @relation("DeviceDefaultPlaylist")

  @@index([organizationId, deletedAt])
  @@map("playlists")
}

model PlaylistItem {
  id                String           @id @default(cuid())
  playlistId        String
  type              PlaylistItemType @default(media)
  mediaAssetId      String?
  folderId          String?
  position          Int
  durationSeconds   Float?
  fitMode           FitMode?
  /// Hex color (#rrggbb) shown behind the media; null = inherit playlist/platform default.
  backgroundColor   String?
  positionMode      PositionMode?
  enabled           Boolean          @default(true)
  includeSubfolders Boolean          @default(false)
  /// null = include all media types (folder entries only).
  filterMediaType   MediaType?
  /// null = include all orientations (folder entries only).
  filterOrientation MediaOrientation?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  playlist   Playlist     @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset?  @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  folder     MediaFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
  @@index([mediaAssetId])
  @@index([folderId])
  @@map("playlist_items")
}

model PlaylistPriorityRule {
  id             String                @id @default(cuid())
  organizationId String
  playlistId     String
  name           String
  /// A rule item plays after every `intervalCount` normal items.
  intervalCount  Int
  selectionMode  PrioritySelectionMode @default(rotate)
  enabled        Boolean               @default(true)
  position       Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?

  organization Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  playlist     Playlist                         @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  assignments  PlaylistPriorityRuleAssignment[]

  @@index([playlistId, deletedAt])
  @@map("playlist_priority_rules")
}

model PlaylistPriorityRuleAssignment {
  id                String   @id @default(cuid())
  organizationId    String
  priorityRuleId    String
  mediaAssetId      String?
  folderId          String?
  includeSubfolders Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  priorityRule PlaylistPriorityRule @relation(fields: [priorityRuleId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset?          @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  folder       MediaFolder?         @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([priorityRuleId])
  @@index([mediaAssetId])
  @@index([folderId])
  @@map("playlist_priority_rule_assignments")
}

model Schedule {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  playlistId     String
  enabled        Boolean   @default(true)
  priority       Int       @default(0)
  startDate      String?
  endDate        String?
  daysOfWeek     Int[]     @default([])
  startTime      String?
  endTime        String?
  timezone       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  playlist          Playlist                   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  deviceAssignments ScheduleDeviceAssignment[]
  groupAssignments  ScheduleGroupAssignment[]

  @@index([organizationId, deletedAt, enabled])
  @@map("schedules")
}

model ScheduleDeviceAssignment {
  id         String   @id @default(cuid())
  scheduleId String
  deviceId   String
  createdAt  DateTime @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  device   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, deviceId])
  @@index([deviceId])
  @@map("schedule_device_assignments")
}

model ScheduleGroupAssignment {
  id         String   @id @default(cuid())
  scheduleId String
  groupId    String
  createdAt  DateTime @default(now())

  schedule Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  group    DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, groupId])
  @@index([groupId])
  @@map("schedule_group_assignments")
}

// ============================================================
// Emergency overrides
// ============================================================

model EmergencyOverride {
  id              String    @id @default(cuid())
  organizationId  String
  name            String?
  playlistId      String?
  mediaAssetId    String?
  active          Boolean   @default(true)
  appliesToAll    Boolean   @default(false)
  // Display settings for single-media overrides (ignored for playlist overrides).
  fitMode         FitMode?
  backgroundColor String?
  positionMode    PositionMode?
  startedAt       DateTime  @default(now())
  stoppedAt       DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  playlist     Playlist?    @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  mediaAsset   MediaAsset?  @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  devices      EmergencyOverrideDevice[]
  groups       EmergencyOverrideGroup[]

  @@index([organizationId, active])
  @@map("emergency_overrides")
}

model EmergencyOverrideDevice {
  id         String   @id @default(cuid())
  overrideId String
  deviceId   String
  createdAt  DateTime @default(now())

  override EmergencyOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)
  device   Device            @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([overrideId, deviceId])
  @@index([deviceId])
  @@map("emergency_override_devices")
}

model EmergencyOverrideGroup {
  id         String   @id @default(cuid())
  overrideId String
  groupId    String
  createdAt  DateTime @default(now())

  override EmergencyOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)
  group    DeviceGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([overrideId, groupId])
  @@index([groupId])
  @@map("emergency_override_groups")
}

// ============================================================
// Device telemetry
// ============================================================

model DeviceCommand {
  id              String        @id @default(cuid())
  deviceId        String
  type            String
  payload         Json          @default("{}")
  status          CommandStatus @default(pending)
  result          Json?
  createdByUserId String?
  expiresAt       DateTime?
  sentAt          DateTime?
  ackedAt         DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  device    Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdBy User?  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([deviceId, status])
  @@index([deviceId, createdAt])
  @@map("device_commands")
}

model DeviceHeartbeat {
  id        String   @id @default(cuid())
  deviceId  String
  payload   Json
  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@map("device_heartbeats")
}

model DeviceLog {
  id        String   @id @default(cuid())
  deviceId  String
  level     String
  message   String
  context   Json?
  loggedAt  DateTime
  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, loggedAt])
  @@map("device_logs")
}

model PlaybackEvent {
  id           String            @id @default(cuid())
  /// Nullable for events recorded before the v2 upgrade (backfilled when possible).
  organizationId String?
  deviceId     String
  mediaAssetId String?
  playlistId   String?
  /// Set when the item was inserted by a priority rule.
  priorityRuleId String?
  /// 'normal' | 'priority' (null for pre-v2 events).
  playedAs     String?
  /// Client-generated id used to deduplicate re-submitted offline batches.
  clientEventId String?
  durationSeconds Float?
  eventType    PlaybackEventType
  detail       Json?
  occurredAt   DateTime
  createdAt    DateTime          @default(now())

  device     Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@unique([deviceId, clientEventId])
  @@index([deviceId, occurredAt])
  @@index([organizationId, mediaAssetId, eventType, occurredAt])
  @@map("playback_events")
}

// ============================================================
// Audit log
// ============================================================

model AuditLog {
  id              String   @id @default(cuid())
  actorUserId     String?
  actorGlobalRole String?
  organizationId  String?
  targetType      String
  targetId        String?
  action          String
  metadata        Json     @default("{}")
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model DeviceScreenshot {
  id         String   @id @default(cuid())
  deviceId   String
  storageKey String
  createdAt  DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@map("device_screenshots")
}
