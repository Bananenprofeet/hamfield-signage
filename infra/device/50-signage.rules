// Allow the unprivileged "signage" user to manage its own services and to
// reboot the device (used by the restart_player and reboot_device commands).
polkit.addRule(function (action, subject) {
  if (subject.user !== "signage") {
    return polkit.Result.NOT_HANDLED;
  }
  if (
    action.id === "org.freedesktop.systemd1.manage-units" &&
    (action.lookup("unit") === "signage-player.service" ||
      action.lookup("unit") === "signage-agent.service")
  ) {
    return polkit.Result.YES;
  }
  if (
    action.id === "org.freedesktop.login1.reboot" ||
    action.id === "org.freedesktop.login1.reboot-multiple-sessions"
  ) {
    return polkit.Result.YES;
  }
  return polkit.Result.NOT_HANDLED;
});
